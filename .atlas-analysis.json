  "keyFeatures": [
    "Project management with team assignment and leader designation",
    "Task tracking with responsible team member assignment",
    "Team member (encargado) management system",
    "PDF report generation for projects, tasks, and team listings",
    "User authentication and session management",
    "PostgreSQL database integration",
    "CRUD operations with soft delete functionality",
    "Bootstrap-based responsive UI"
  ],
  "publicApiSurface": [
    "viewProyectos - Project management view with CRUD operations",
    "viewTareas - Task management view with CRUD operations",
    "viewtrabajadores - Team member management view with CRUD operations",
    "Proyectos - Project model with name, leader, and team members",
    "Tareas - Task model with name and assigned team member",
    "encargado - Team member model",
    "ProjectForm - Form for creating and editing projects",
    "TareasForm - Form for creating and editing tasks",
    "trabajadoresForm - Form for creating and editing team members"
  ]
